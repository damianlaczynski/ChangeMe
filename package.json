{
  "name": "changeme",
  "private": true,
  "scripts": {
    "install:frontend": "npm --prefix src/ChangeMe.Frontend install && npm --prefix src/ChangeMe.Frontend exec playwright install chromium",
    "start:frontend": "npm --prefix src/ChangeMe.Frontend run start",
    "start:backend": "dotnet run --project src/ChangeMe.Backend/src/ChangeMe.Backend.Web/ChangeMe.Backend.Web.csproj",
    "start:all": "concurrently -n frontend,backend -c cyan,green \"npm run start:frontend\" \"npm run start:backend\"",
    "build:frontend": "npm --prefix src/ChangeMe.Frontend run build",
    "build:backend": "dotnet build src/ChangeMe.Backend/ChangeMe.Backend.slnx",
    "build:all": "npm run build:frontend && npm run build:backend",
    "lint:frontend": "npm --prefix src/ChangeMe.Frontend run lint",
    "format:check:frontend": "npm --prefix src/ChangeMe.Frontend run format:check",
    "format:check:backend": "dotnet format src/ChangeMe.Backend/ChangeMe.Backend.slnx --verify-no-changes --exclude \"**/Persistence/Migrations/**\"",
    "format:check:all": "npm run format:check:frontend && npm run format:check:backend",
    "format:frontend": "npm --prefix src/ChangeMe.Frontend run format",
    "format:backend": "dotnet format src/ChangeMe.Backend/ChangeMe.Backend.slnx --exclude \"**/Persistence/Migrations/**\"",
    "format:all": "npm run format:frontend && npm run format:backend",
    "test:frontend": "npm --prefix src/ChangeMe.Frontend run test",
    "test:frontend:ci": "npm --prefix src/ChangeMe.Frontend run test -- --watch=false",
    "test:frontend:coverage": "npm --prefix src/ChangeMe.Frontend run test -- --watch=false --coverage",
    "test:backend": "dotnet test src/ChangeMe.Backend/ChangeMe.Backend.slnx",
    "test:backend:unit": "dotnet test src/ChangeMe.Backend/tests/ChangeMe.Backend.UnitTests",
    "test:backend:integration": "dotnet test src/ChangeMe.Backend/tests/ChangeMe.Backend.IntegrationTests",
    "test:all": "concurrently -n fe,be -c cyan,blue \"npm run test:frontend:ci\" \"npm run test:backend\"",
    "test:e2e": "npm --prefix src/ChangeMe.Frontend run e2e",
    "test:e2e:ui": "npm --prefix src/ChangeMe.Frontend run e2e:ui",
    "ef:migrations:add": "dotnet ef migrations add --project src/ChangeMe.Backend/src/ChangeMe.Backend.Infrastructure/ChangeMe.Backend.Infrastructure.csproj --startup-project src/ChangeMe.Backend/src/ChangeMe.Backend.Web/ChangeMe.Backend.Web.csproj --output-dir Persistence/Migrations",
    "ef:migrations:remove": "dotnet ef migrations remove --project src/ChangeMe.Backend/src/ChangeMe.Backend.Infrastructure/ChangeMe.Backend.Infrastructure.csproj --startup-project src/ChangeMe.Backend/src/ChangeMe.Backend.Web/ChangeMe.Backend.Web.csproj",
    "ef:database:update": "dotnet ef database update --project src/ChangeMe.Backend/src/ChangeMe.Backend.Infrastructure/ChangeMe.Backend.Infrastructure.csproj --startup-project src/ChangeMe.Backend/src/ChangeMe.Backend.Web/ChangeMe.Backend.Web.csproj",
    "data:generate": "dotnet run --no-launch-profile --project src/ChangeMe.Backend/tools/ChangeMe.Backend.DataGenerator/ChangeMe.Backend.DataGenerator.csproj --",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "docker:test:backend": "docker compose --profile test run --rm backend-tests",
    "requirements:validate": "node scripts/requirements-validate.mjs"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
