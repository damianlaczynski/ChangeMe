{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "changeme-frontend: serve",
      "type": "process",
      "command": "npm",
      "args": ["run", "start", "--", "--host", "0.0.0.0", "--port", "4200"],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Frontend"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Application bundle generation complete"
        }
      }
    },
    {
      "label": "changeme-frontend: build",
      "type": "process",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "changeme-frontend: lint",
      "type": "process",
      "command": "npm",
      "args": ["run", "lint"],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Frontend"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "changeme-frontend: format",
      "type": "process",
      "command": "npm",
      "args": ["run", "format"],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Frontend"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "changeme-frontend: format check",
      "type": "process",
      "command": "npm",
      "args": ["run", "format:check"],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Frontend"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "changeme-backend: build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/ChangeMe.Backend/src/ChangeMe.Backend.Web/ChangeMe.Backend.Web.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Backend/src/ChangeMe.Backend.Web"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "changeme-backend: build solution",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/ChangeMe.Backend/ChangeMe.Backend.slnx",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary;ForceNoAlign"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Backend"
      },
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "changeme-backend: format",
      "type": "process",
      "command": "dotnet",
      "args": [
        "format",
        "${workspaceFolder}/src/ChangeMe.Backend/ChangeMe.Backend.slnx"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Backend"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "changeme-backend: format check",
      "type": "process",
      "command": "dotnet",
      "args": [
        "format",
        "${workspaceFolder}/src/ChangeMe.Backend/ChangeMe.Backend.slnx",
        "--verify-no-changes"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/ChangeMe.Backend"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "changeme: lint all",
      "dependsOrder": "sequence",
      "dependsOn": ["changeme-frontend: lint"]
    },
    {
      "label": "changeme: build all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "changeme-frontend: build",
        "changeme-backend: build solution"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "changeme: format all",
      "dependsOrder": "sequence",
      "dependsOn": ["changeme-frontend: format", "changeme-backend: format"]
    },
    {
      "label": "changeme: verify all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "changeme-frontend: format check",
        "changeme-frontend: lint",
        "changeme-backend: format check",
        "changeme-backend: build solution"
      ],
      "group": "test"
    }
  ]
}
