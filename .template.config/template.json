{
  "$schema": "https://json.schemastore.org/template",
  "author": "Damian Łączyński",
  "classifications": ["Web", "API", "SPA"],
  "identity": "ChangeMe.FullStack",
  "name": "ChangeMe full-stack",
  "shortName": "changeme",
  "sourceName": "ChangeMe",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "symbols": {
    "ProjectNameCamelCase": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "projectNameCamelCase",
      "replaces": "changeMe"
    }
  },
  "forms": {
    "projectNameCamelCase": {
      "identifier": "firstLowerCaseInvariant"
    }
  },
  "primaryOutputs": [{ "path": "src/ChangeMe.Backend/ChangeMe.Backend.slnx" }],
  "sources": [
    {
      "source": "./",
      "target": "./",
      "modifiers": [
        {
          "exclude": [
            ".template.config/**",
            "template-content/**",
            ".git/**",
            ".angular/**",
            ".tmp-template-inspect/**",
            ".template-test-output/**",
            "artifacts/**",
            "template-pack/**",
            "**/node_modules/**",
            "**/bin/**",
            "**/obj/**",
            "**/dist/**",
            "**/.vs/**",
            "**/TestResults/**",
            "**/logs/**",
            "*.nupkg",
            "README.md",
            "CONTRIBUTING.md",
            "src/ChangeMe.Backend/src/ChangeMe.Backend.Infrastructure/Persistence/Migrations/**"
          ]
        }
      ]
    },
    {
      "source": "template-content/generated-readme/",
      "target": "./"
    }
  ]
}
