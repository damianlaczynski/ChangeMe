{
  "$schema": "https://json.schemastore.org/template",
  "author": "Damian Łączyński",
  "classifications": ["Web", "API", "SPA"],
  "identity": "ChangeMe.FullStack",
  "name": "ChangeMe full-stack",
  "shortName": "changeme",
  "sourceName": "ChangeMe",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "symbols": {
    "ProjectNameCamelCase": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "projectNameCamelCase",
      "replaces": "changeMe"
    },
    "ProjectNameScreamingSnake": {
      "type": "derived",
      "valueSource": "name",
      "valueTransform": "projectNameScreamingSnake",
      "replaces": "CHANGE_ME"
    }
  },
  "forms": {
    "projectNameCamelCase": {
      "identifier": "firstLowerCaseInvariant"
    },
    "projectNameScreamingSnake": {
      "identifier": "chain",
      "steps": ["projectNamePascalToSnake", "projectNameUpperCase"]
    },
    "projectNamePascalToSnake": {
      "identifier": "replace",
      "pattern": "([a-z])([A-Z])",
      "replacement": "$1_$2"
    },
    "projectNameUpperCase": {
      "identifier": "upperCaseInvariant"
    }
  },
  "primaryOutputs": [{ "path": "src/ChangeMe.Backend/ChangeMe.Backend.slnx" }],
  "sources": [
    {
      "source": "./",
      "target": "./",
      "modifiers": [
        {
          "exclude": [
            ".template.config/**",
            "template-content/**",
            ".git/**",
            ".angular/**",
            ".tmp-template-inspect/**",
            ".template-test-output/**",
            "artifacts/**",
            "template-pack/**",
            "**/node_modules/**",
            "**/bin/**",
            "**/obj/**",
            "**/dist/**",
            "**/.vs/**",
            "**/TestResults/**",
            "**/logs/**",
            "*.nupkg",
            "README.md",
            "CONTRIBUTING.md",
            "CHANGELOG.md"
          ]
        }
      ]
    },
    {
      "source": "template-content/generated-readme/",
      "target": "./"
    }
  ]
}
