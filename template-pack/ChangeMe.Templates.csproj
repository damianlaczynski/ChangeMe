<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoWarn>$(NoWarn);NU5128</NoWarn>

    <PackageId>ChangeMe</PackageId>
    <Version>2.1.0</Version>
    <PackageReleaseNotes>See CHANGELOG.md — optimistic concurrency, API rate limiting, security headers (CSP nonce), Docker hardening.</PackageReleaseNotes>
    <Title>ChangeMe</Title>
    <Authors>Damian Łączyński</Authors>
    <Description>Full-stack dotnet new starter template with Angular frontend, layered ASP.NET backend, PostgreSQL, Docker Compose, tests, and project documentation.</Description>
    <PackageTags>dotnet-new;template;starter;angular;aspnetcore;fullstack</PackageTags>
    <PackageType>Template</PackageType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>NuGetPackageREADME.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/damianlaczynski/ChangeMe</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageProjectUrl>https://github.com/damianlaczynski/ChangeMe</PackageProjectUrl>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <Copyright>Copyright (c) 2026 Damian Łączyński</Copyright>
  </PropertyGroup>

  <ItemGroup>
    <None Include="NuGetPackageREADME.md" Pack="true" PackagePath="\" />
    <Content Include="..\**\*"
             Exclude="
               ..\.git\**;
               ..\.angular\**;
               ..\.template-test\**;
               ..\template-pack\**;
               ..\artifacts\**;
               ..\**\bin\**;
               ..\**\obj\**;
               ..\**\node_modules\**;
               ..\**\dist\**;
               ..\**\.vs\**;
               ..\**\TestResults\**;
               ..\**\logs\**;
               ..\**\*.log;
               ..\*.nupkg"
             Pack="true"
             PackagePath="content" />
  </ItemGroup>

</Project>
