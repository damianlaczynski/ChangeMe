<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local QueryGrid feed (sibling repo). Run `npm run pack:dotnet` in query-grid after clone. -->
    <add key="querygrid-local" value="../query-grid/artifacts/nuget" />
    <add key="github" value="https://nuget.pkg.github.com/damianlaczynski/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="querygrid-local">
      <package pattern="QueryGrid.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
