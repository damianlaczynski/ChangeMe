{
  "name": "changeme.frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0"
  },
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --coverage",
    "e2e": "playwright test -c e2e/playwright.config.ts",
    "e2e:ui": "playwright test -c e2e/playwright.config.ts --ui",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css}\" src/index.html",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css}\" src/index.html"
  },
  "dependencies": {
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.7",
    "@angular/compiler": "^22.0.7",
    "@angular/core": "^22.0.7",
    "@angular/forms": "^22.0.7",
    "@angular/platform-browser": "^22.0.7",
    "@angular/router": "^22.0.7",
    "@fontsource-variable/inter": "^5.3.0",
    "@microsoft/signalr": "^10.0.0",
    "@primeuix/themes": "^3.0.0",
    "@query-grid/core": "0.1.0-preview.7",
    "@query-grid/primeng": "0.1.0-preview.7",
    "@tailwindcss/postcss": "^4.3.3",
    "postcss": "^8.5.21",
    "primeicons": "^8.0.0",
    "primeng": "^22.0.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.3.3",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^22.1.0",
    "@angular-eslint/eslint-plugin-template": "^22.1.0",
    "@angular-eslint/template-parser": "^22.1.0",
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.7",
    "angular-eslint": "^22.1.0",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@query-grid/primeng": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core",
      "@angular/forms": "$@angular/forms",
      "primeng": "$primeng"
    }
  }
}
