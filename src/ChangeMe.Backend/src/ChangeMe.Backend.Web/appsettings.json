{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "Notifications": {
    "Retention": {
      "UnreadRetentionDays": 90,
      "ReadRetentionDays": 30,
      "AbsoluteRetentionDays": 180,
      "CleanupCronExpression": "0 3 * * *"
    }
  },
  "FileStorage": {
    "RootPath": "../../storage",
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [
      ".pdf",
      ".png",
      ".jpg",
      ".jpeg",
      ".gif",
      ".txt",
      ".csv",
      ".docx",
      ".xlsx"
    ],
    "CleanupCronExpression": "0 * * * *",
    "CleanupConcurrentExecutionTimeoutSeconds": 3600
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Auth": {
    "FrontendBaseUrl": "http://localhost:4200",
    "Jwt": {
      "Issuer": "ChangeMe",
      "Audience": "ChangeMe.Client",
      "SigningKey": "ChangeMe-SuperSecretSigningKey-ForJwt-AtLeast32Chars",
      "ExpirationMinutes": 30,
      "SessionLifetimeDays": 14
    },
    "PasswordPolicy": {
      "MinimumLength": 8,
      "MaximumLength": 128,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireSpecialCharacter": true
    },
    "PasswordExpiration": {
      "Enabled": true,
      "MaximumPasswordAgeDays": 90
    },
    "EmailVerification": {
      "Enabled": true,
      "LinkLifetimeHours": 72
    },
    "Registration": {
      "PublicEnabled": true
    },
    "PasswordReset": {
      "LinkLifetimeHours": 24
    },
    "Invitations": {
      "InvitationLinkLifetimeHours": 72,
      "Retention": {
        "RevokedInvitationRetentionDays": 7,
        "CleanupCronExpression": "0 4 * * *"
      }
    },
    "Passkeys": {
      "PasskeysAuthenticationEnabled": false,
      "PasskeysAuthenticationRequired": false,
      "PasskeySatisfiesTwoFactor": false,
      "AllowPasskeyOnlyAccounts": false,
      "DiscoverablePasskeySignInOnLogin": true,
      "OfferPasskeyEnrollmentPrompt": false,
      "RelyingPartyDisplayName": "ChangeMe",
      "MaximumPasskeysPerUser": 10,
      "ChallengeLifetimeMinutes": 5,
      "UserVerificationRequired": true,
      "AllowedAuthenticatorAttachment": "Any",
      "AttestationConveyance": "None",
      "PasskeyStepUpValidityMinutes": 15,
      "MaxFailedPasskeyAttempts": 5
    },
    "TwoFactor": {
      "Enabled": false,
      "Required": false,
      "TrustIdentityProviderMfa": false,
      "TotpTimeStepSeconds": 30,
      "TotpValidationWindowSteps": 1,
      "VerificationCodeLength": 6,
      "RecoveryCodeCount": 10,
      "PendingSignInChallengeLifetimeMinutes": 10,
      "MaxFailedVerificationAttempts": 5,
      "StepUpExternalSignInValidityMinutes": 15,
      "TotpIssuerName": "ChangeMe"
    },
    "External": {
      "Enabled": false,
      "PendingLifetimeMinutes": 10,
      "SignInCallbackPath": "/external-sign-in/callback",
      "Providers": [
        {
          "ProviderKey": "google",
          "DisplayName": "Google",
          "Authority": "https://accounts.google.com",
          "ClientId": "",
          "ClientSecret": "",
          "AllowedEmailDomains": [],
          "IssuerValidationMode": "Discovery",
          "TrustIdpEmailWithoutEmailVerified": false
        },
        {
          "ProviderKey": "keycloak",
          "DisplayName": "Keycloak",
          "Authority": "https://keycloak.example.com/realms/your-realm",
          "ClientId": "",
          "ClientSecret": "",
          "AllowedEmailDomains": [],
          "IssuerValidationMode": "Discovery",
          "TrustIdpEmailWithoutEmailVerified": false
        },
        {
          "ProviderKey": "microsoft",
          "DisplayName": "Microsoft",
          "Authority": "https://login.microsoftonline.com/common/v2.0",
          "ClientId": "",
          "ClientSecret": "",
          "AllowedEmailDomains": [],
          "IssuerValidationMode": "MicrosoftMultiTenant",
          "TrustIdpEmailWithoutEmailVerified": true
        }
      ]
    }
  },
  "InitialAdministrator": {
    "Email": "",
    "Password": "",
    "FirstName": "",
    "LastName": ""
  },
  "Email": {
    "Host": "",
    "Port": 1025,
    "EnableSsl": false,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": ""
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../../logs/changeme.backend-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true,
          "outputTemplate": "{Timestamp:O} [{Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
