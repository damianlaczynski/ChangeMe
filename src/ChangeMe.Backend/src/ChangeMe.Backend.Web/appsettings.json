{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "Notifications": {
    "Retention": {
      "UnreadRetentionDays": 90,
      "ReadRetentionDays": 30,
      "AbsoluteRetentionDays": 180,
      "CleanupCronExpression": "0 3 * * *"
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Auth": {
    "FrontendBaseUrl": "http://localhost:4200",
    "Jwt": {
      "Issuer": "ChangeMe",
      "Audience": "ChangeMe.Client",
      "SigningKey": "ChangeMe-SuperSecretSigningKey-ForJwt-AtLeast32Chars",
      "ExpirationMinutes": 30,
      "SessionLifetimeDays": 14
    },
    "PasswordPolicy": {
      "MinimumLength": 8,
      "MaximumLength": 128,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireSpecialCharacter": true
    },
    "PasswordExpirationEnabled": true,
    "MaximumPasswordAgeDays": 90,
    "EmailVerificationEnabled": true,
    "EmailVerificationLinkLifetimeHours": 72,
    "PublicRegistrationEnabled": true,
    "PasswordResetLinkLifetimeHours": 24,
    "InvitationLinkLifetimeHours": 72,
    "TwoFactorAuthenticationEnabled": false,
    "TwoFactorAuthenticationRequired": false,
    "TrustIdentityProviderMfa": false,
    "TwoFactor": {
      "TotpTimeStepSeconds": 30,
      "TotpValidationWindowSteps": 1,
      "VerificationCodeLength": 6,
      "RecoveryCodeCount": 10,
      "PendingSignInChallengeLifetimeMinutes": 10,
      "MaxFailedVerificationAttempts": 5,
      "StepUpExternalSignInValidityMinutes": 15,
      "TotpIssuerName": "ChangeMe"
    },
    "ExternalProvidersEnabled": false,
    "ExternalProviders": []
  },
  "InitialAdministrator": {
    "Email": "",
    "Password": "",
    "FirstName": "",
    "LastName": ""
  },
  "Email": {
    "Host": "",
    "Port": 1025,
    "EnableSsl": false,
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": ""
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../../logs/changeme.backend-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true,
          "outputTemplate": "{Timestamp:O} [{Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
