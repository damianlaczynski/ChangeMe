{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=ChangeMe;Username=postgres;Password=postgres"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  },
  "Notifications": {
    "Retention": {
      "UnreadRetentionDays": 90,
      "ReadRetentionDays": 30,
      "AbsoluteRetentionDays": 180,
      "CleanupCronExpression": "0 3 * * *"
    }
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200", "https://localhost:4200"]
  },
  "Auth": {
    "FrontendBaseUrl": "http://localhost:4200",
    "Jwt": {
      "Issuer": "ChangeMe.Dev",
      "Audience": "ChangeMe.Frontend",
      "SigningKey": "Development-Signing-Key-For-Jwt-Needs-32-Characters",
      "ExpirationMinutes": 30,
      "SessionLifetimeDays": 14
    },
    "PasswordPolicy": {
      "MinimumLength": 8,
      "MaximumLength": 128,
      "RequireUppercase": true,
      "RequireLowercase": true,
      "RequireDigit": true,
      "RequireSpecialCharacter": false
    },
    "PasswordExpirationEnabled": true,
    "MaximumPasswordAgeDays": 90,
    "EmailVerificationEnabled": true,
    "EmailVerificationLinkLifetimeHours": 72,
    "PublicRegistrationEnabled": true,
    "PasswordResetLinkLifetimeHours": 24,
    "InvitationLinkLifetimeHours": 72,
    "TwoFactorAuthenticationEnabled": true,
    "TwoFactorAuthenticationRequired": false,
    "TrustIdentityProviderMfa": false,
    "TwoFactor": {
      "TotpTimeStepSeconds": 30,
      "TotpValidationWindowSteps": 1,
      "VerificationCodeLength": 6,
      "RecoveryCodeCount": 10,
      "PendingSignInChallengeLifetimeMinutes": 10,
      "MaxFailedVerificationAttempts": 5,
      "StepUpExternalSignInValidityMinutes": 15,
      "TotpIssuerName": "ChangeMe"
    },
    "ExternalAuthPendingLifetimeMinutes": 10,
    "ExternalSignInCallbackPath": "/external-sign-in/callback",
    "ExternalProvidersEnabled": true,
    "ExternalProviders": [
      {
        "ProviderKey": "google",
        "DisplayName": "Google",
        "Authority": "https://accounts.google.com",
        "ClientId": "",
        "ClientSecret": "",
        "AllowedEmailDomains": [],
        "IssuerValidationMode": "Discovery",
        "TrustIdpEmailWithoutEmailVerified": false
      },
      {
        "ProviderKey": "keycloak",
        "DisplayName": "Keycloak",
        "Authority": "https://keycloak.example.com/realms/your-realm",
        "ClientId": "",
        "ClientSecret": "",
        "AllowedEmailDomains": [],
        "IssuerValidationMode": "Discovery",
        "TrustIdpEmailWithoutEmailVerified": false
      },
      {
        "ProviderKey": "microsoft",
        "DisplayName": "Microsoft",
        "Authority": "https://login.microsoftonline.com/common/v2.0",
        "ClientId": "",
        "ClientSecret": "",
        "AllowedEmailDomains": [],
        "IssuerValidationMode": "MicrosoftMultiTenant",
        "TrustIdpEmailWithoutEmailVerified": true
      }
    ]
  },
  "InitialAdministrator": {
    "Email": "admin@example.local",
    "Password": "admin123",
    "FirstName": "System",
    "LastName": "Administrator"
  },
  "DataGenerator": {
    "Seed": 20260522,
    "Users": 8,
    "Issues": 25,
    "CommentsPerIssueMin": 0,
    "CommentsPerIssueMax": 4,
    "NotificationsPerUserMin": 0,
    "NotificationsPerUserMax": 3,
    "DefaultPassword": "Demo123!",
    "EmailDomain": "demo.local"
  },
  "Email": {
    "Host": "localhost",
    "Port": 1025,
    "EnableSsl": false,
    "Username": "",
    "Password": "",
    "FromEmail": "no-reply@example.local",
    "FromName": "ChangeMe System"
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:O}] [{Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "../../logs/changeme.backend-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 1,
          "shared": true,
          "outputTemplate": "{Timestamp:O} [{Level:u3}] {SourceContext} | {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
